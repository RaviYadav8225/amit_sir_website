{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/services/layout,_N_T_/services/web-hosting/layout,_N_T_/services/web-hosting/page,_N_T_/services/web-hosting"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/services/web-hosting/__PAGE__",
    "/services/web-hosting",
    "/services",
    "/_index",
    "/_head"
  ]
}