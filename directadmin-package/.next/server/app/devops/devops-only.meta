{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/devops/layout,_N_T_/devops/devops-only/layout,_N_T_/devops/devops-only/page,_N_T_/devops/devops-only"
  },
